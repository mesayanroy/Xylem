# ────────────────────────────────────────────────────────────────────────────
# agents-sdk — Xylem AgentForge Rust Agent Templates
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env inside each agent sub-directory and fill in values.

# ── Stellar Network ──────────────────────────────────────────────────────────
# Mainnet:  https://horizon.stellar.org
# Testnet:  https://horizon-testnet.stellar.org  (default)
HORIZON_URL=https://horizon-testnet.stellar.org

# Network passphrase (must match HORIZON_URL):
#   Mainnet: "Public Global Stellar Network ; September 2015"
#   Testnet: "Test SDF Network ; September 2015"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Wallet ───────────────────────────────────────────────────────────────────
# Your Stellar secret key (starts with S…).  Never commit this!
AGENT_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Smart Contract ───────────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Fee settings ─────────────────────────────────────────────────────────────
BASE_FEE_STROOPS=100
MAX_SLIPPAGE_BPS=50

# ── 0x402 Payment Protocol ───────────────────────────────────────────────────
# URL of the AgentForge platform (used for agent-to-agent calls).
PLATFORM_API_URL=https://agentforge.xyz
# How much XLM to accept as the maximum relay fee when calling other agents.
MAX_RELAY_FEE_XLM=0.01

# ── Kafka / Upstash Pub-Sub ──────────────────────────────────────────────────
# Leave blank to disable Kafka publishing (agents will still function).
UPSTASH_KAFKA_BROKER=
UPSTASH_KAFKA_USERNAME=
UPSTASH_KAFKA_PASSWORD=

# ── Logging ──────────────────────────────────────────────────────────────────
# Comma-separated tracing directives: e.g. "info", "debug", "mev_bot=debug"
LOG_LEVEL=info
