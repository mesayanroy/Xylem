# ────────────────────────────────────────────────────────────────
# Agent SDK — Environment Template
# Copy to .env and fill in your values before running.
# ────────────────────────────────────────────────────────────────

# ── Stellar Wallet ───────────────────────────────────────────────
# ed25519 seed — Strkey format starting with 'S'
# Generate: stellar-sdk keypair generate  or  stellar-cli keys generate
AGENT_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Stellar Network ──────────────────────────────────────────────
# Testnet
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Mainnet (uncomment when ready)
# HORIZON_URL=https://horizon.stellar.org
# NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# ── Soroban (on-chain agent registry) ───────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=<agent-registry-contract-id>

# ── Gas / Fees ───────────────────────────────────────────────────
# Base fee in stroops (100 = 0.00001 XLM per operation)
BASE_FEE_STROOPS=100
# Max slippage tolerance in basis points (50 = 0.5%)
MAX_SLIPPAGE_BPS=50

# ── 0x402 Payment Protocol ───────────────────────────────────────
# URL of the AgentForge platform API (for paying agents via 0x402)
PLATFORM_API_URL=https://agentforge.xyz
# Optional: URL of an external price-feed agent this agent pays for data
PRICE_FEED_AGENT_URL=

# ── Upstash Kafka (pub-sub backbone) ─────────────────────────────
UPSTASH_KAFKA_BROKER=https://YOUR_BROKER.upstash.io
UPSTASH_KAFKA_USERNAME=YOUR_USERNAME
UPSTASH_KAFKA_PASSWORD=YOUR_PASSWORD

# ── Logging ──────────────────────────────────────────────────────
RUST_LOG=info

# ── Relayer ───────────────────────────────────────────────────────
# Enable fee-bump wrapping (true) or plain relay (false)
FEE_BUMP_ENABLED=true
# Multiplier applied to base fee when bumping (e.g. 1.5 = 50% above base)
FEE_BUMP_MULTIPLIER=1.5
# Maximum fee in stroops the relayer is willing to pay per relay
MAX_RELAY_FEE_STROOPS=10000
# Price charged to callers in XLM (via 0x402) per relay
RELAY_PRICE_XLM=0.001
# HTTP server port for relay requests
RELAY_SERVER_PORT=8080
