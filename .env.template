# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Stellar / Horizon ────────────────────────────────────────────────────────
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=your_deployed_contract_id
# Server-side agent payout wallet (Stellar secret key – never expose to client)
STELLAR_AGENT_SECRET=your_stellar_secret_key

# ─── Upstash Kafka ────────────────────────────────────────────────────────────
# Get these from https://console.upstash.com → Kafka → your cluster
UPSTASH_KAFKA_BROKER=your-cluster-url.upstash.io:9092
UPSTASH_KAFKA_USERNAME=your_kafka_username
UPSTASH_KAFKA_PASSWORD=your_kafka_password

# ─── Ably ─────────────────────────────────────────────────────────────────────
# Get this from https://ably.com → App → API Keys
ABLY_API_KEY=your_ably_api_key
# Exposed to browser only for subscribing (use a subscribe-only key)
NEXT_PUBLIC_ABLY_KEY=your_ably_subscribe_only_key
